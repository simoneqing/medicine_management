.container { padding: 24rpx; background:#f5f7fb; min-height:100vh; }
.card { background:#fff; border-radius:18rpx; padding:18rpx; margin-bottom:14rpx; }
.title { font-size:34rpx; font-weight:700; }
.label { font-size:28rpx; font-weight:600; }
.value { font-size:42rpx; color:#2563eb; font-weight:800; }
.muted { color:#6b7280; font-size:24rpx; margin-top:6rpx; }
.grid-two { display:grid; grid-template-columns:1fr 1fr; gap:12rpx; }
.filters { display:flex; gap:10rpx; margin-top:8rpx; }
.filter { padding:6rpx 16rpx; border:1px solid #d1d5db; border-radius:999rpx; color:#6b7280; font-size:24rpx; }
.filter.active { background:#2563eb; color:#fff; border-color:#2563eb; }
.custom-wrap { margin-top:10rpx; display:grid; gap:8rpx; }
.picker { padding:10rpx; border:1px solid #d1d5db; border-radius:10rpx; }
.list-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:8rpx; }
.item { border:1px solid #e5e7eb; border-radius:12rpx; padding:12rpx; margin-bottom:10rpx; }
.item-head { display:flex; justify-content:space-between; font-size:24rpx; }
.new-item { border-color:#60a5fa; background:#eff6ff; }
.new-tag { color:#1d4ed8; font-size:20rpx; }
.drawer { position:fixed; inset:0; background:rgba(0,0,0,.35); display:flex; align-items:flex-end; }
.drawer-panel { width:100%; background:#fff; border-radius:20rpx 20rpx 0 0; padding:16rpx; max-height:84vh; overflow:auto; }
.field { margin-bottom:10rpx; }
.spec-row { display:grid; grid-template-columns:1fr 1fr; gap:8rpx; margin-bottom:8rpx; align-items:center; }
.compact { margin:10rpx 0; }
.fab { position:fixed; right:20rpx; bottom:30rpx; width:90rpx; height:90rpx; border-radius:45rpx; background:#2563eb; color:#fff; font-size:48rpx; border:none; }


.drawer-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:8rpx; }
.close-text { color:#94a3b8; font-size:24rpx; }
.stepper { display:flex; align-items:center; gap:8rpx; }
.count { min-width: 34rpx; text-align:center; font-weight:700; }
.drawer-footer { position: sticky; bottom: 0; background:#fff; padding-top: 10rpx; }
