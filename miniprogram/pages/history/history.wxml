<view class="container">
  <view class="card">
    <view class="title">历史记录工作台</view>
    <view class="muted">历史记录主页面，支持筛选与新增闭环</view>
  </view>

  <view class="grid-two">
    <view class="card stat-card"><view class="label">历史总用药次数</view><view class="value"><text class="num">{{stats.total}}</text><text class="unit">次</text></view></view>
    <view class="card stat-card"><view class="label">本年用药次数</view><view class="value"><text class="num">{{stats.year}}</text><text class="unit">次</text></view></view>
  </view>

  <view class="card">
    <view class="label">时间筛选</view>
    <view class="filters">
      <view class="filter {{filterMode==='week'?'active':''}}" data-mode="week" bindtap="switchFilter">本周</view>
      <view class="filter {{filterMode==='month'?'active':''}}" data-mode="month" bindtap="switchFilter">本月</view>
      <view class="filter {{filterMode==='custom'?'active':''}}" data-mode="custom" bindtap="switchFilter">自定义</view>
    </view>
    <view wx:if="{{filterMode==='custom'}}" class="custom-wrap">
      <picker mode="date" value="{{customStart}}" bindchange="onCustomStart"><view class="picker">开始：{{customStart}}</view></picker>
      <picker mode="date" value="{{customEnd}}" bindchange="onCustomEnd"><view class="picker">结束：{{customEnd}}</view></picker>
    </view>
  </view>

  <view class="card">
    <view class="list-head">
      <view class="label">历史记录</view>
    </view>
    <block wx:for="{{filteredRecords}}" wx:key="id">
      <view class="item {{item.isNew ? 'new-item' : ''}}">
        <view class="item-head">
          <text class="item-time">{{item.timeText}}</text>
          <view class="item-brand-wrap">
            <text class="item-brand">{{item.brand}}</text>
            <text wx:if="{{item.isNew}}" class="new-tag">刚刚新增</text>
          </view>
        </view>
        <view class="kv-line"><text class="kv-label">规格组合</text><text class="kv-value">{{item.specText}}</text></view>
        <view class="kv-line"><text class="kv-label">总剂量</text><text class="kv-value">{{item.totalDose}}</text></view>
        <view class="kv-line"><text class="kv-label">预计提升浓度</text><text class="kv-value strong">{{item.expectedRise}}</text></view>
        <view class="item-actions" wx:if="{{item.canEdit || item.canDelete}}">
          <button
            wx:if="{{item.canEdit}}"
            class="edit-btn"
            size="mini"
            data-id="{{item.id}}"
            bindtap="onEditRecord"
          >
            编辑
          </button>
          <button
            wx:if="{{item.canDelete}}"
            class="delete-btn"
            size="mini"
            type="warn"
            data-id="{{item.id}}"
            loading="{{deletingId===item.id}}"
            disabled="{{deletingId===item.id}}"
            bindtap="onDeleteRecord"
          >
            删除
          </button>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{showAddForm}}" class="drawer">
    <view class="drawer-panel">
      <view class="drawer-head"><view class="label">{{editingRecordId ? '编辑用药记录' : '新增用药记录'}}</view><text class="close-text" bindtap="closeAddForm">关闭</text></view>
      <view class="field">
        <text>用药日期</text>
        <picker mode="date" value="{{formDate}}" bindchange="onFormDate">
          <view class="picker">{{formDate}}</view>
        </picker>
      </view>
      <view class="field">
        <text>用药时间</text>
        <picker mode="time" value="{{formClock}}" bindchange="onFormClock">
          <view class="picker">{{formClock}}</view>
        </picker>
      </view>
      <view class="field"><text>药品品牌</text>
        <picker range="{{medicineOptions}}" range-key="brand" value="{{selectedMedicineIndex}}" bindchange="onMedicineChange">
          <view class="picker">{{medicineOptions.length ? medicineOptions[selectedMedicineIndex].brand : '请先维护药品'}}</view>
        </picker>
      </view>
      <view class="muted">本次使用规格（未使用的规格保持为 0）</view>
      <block wx:for="{{specInputs}}" wx:key="spec">
        <view class="spec-row">
          <text>{{item.spec}} {{item.unit}}</text>
          <view class="stepper">
            <button size="mini" data-index="{{index}}" data-op="minus" bindtap="stepSpec">-</button>
            <text class="count">{{item.count}}</text>
            <button size="mini" data-index="{{index}}" data-op="plus" bindtap="stepSpec">+</button>
          </view>
        </view>
      </block>

      <view class="card compact calc-card">
        <view class="muted">总剂量：{{calc.totalDose}}</view>
        <view class="muted">当前体重：{{calc.weight}}</view>
        <view class="muted">回收率：{{calc.recoveryRate}}</view>
        <view class="muted">预计提升浓度：{{calc.expectedRise}}%</view>
        <view class="muted">计算明细：{{calc.detail}}</view>
      </view>

      <view class="drawer-footer"><button type="primary" loading="{{submitting}}" bindtap="submitRecord">{{submitting ? '提交中...' : (editingRecordId ? '保存修改' : '提交记录')}}</button></view>
    </view>
  </view>

  <button wx:if="{{!showAddForm}}" class="fab" bindtap="openAddForm">＋</button>
</view>
