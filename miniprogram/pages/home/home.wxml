<view class="container">
  <view class="header">
    <view class="header-title">用药管理 · 首页</view>
    <view class="header-subtitle">所有品牌记录统一累计浓度</view>
  </view>

  <view class="grid-two">
    <view class="card">
      <view class="card-title">本周用药统计</view>
      <view class="row"><text>用药次数</text><text class="value">{{weeklyStats.count}} 次</text></view>
      <view class="row"><text>总量</text><text class="value">{{weeklyStats.totalDoseIU}} IU</text></view>
    </view>

    <view class="card">
      <view class="card-title">本月用药统计</view>
      <view class="row"><text>用药次数</text><text class="value">{{monthlyStats.count}} 次</text></view>
      <view class="row"><text>总量</text><text class="value">{{monthlyStats.totalDoseIU}} IU</text></view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">最近用药</view>
    <block wx:if="{{recentRecords.length}}">
      <block wx:for="{{recentRecords}}" wx:key="id">
        <view class="recent-row">
          <view class="recent-left">{{item.specText}}，{{item.brand}}</view>
          <view class="recent-right">{{item.timeText}}，{{item.weekday}}，{{item.dateText}}</view>
        </view>
      </block>
    </block>
    <view wx:else class="muted">暂无最近用药记录</view>
  </view>

  <view class="card">
    <view class="conc-row">
      <view class="conc-label">当前因子浓度</view>
      <view class="conc">{{currentConcentration}} %</view>
    </view>
  </view>

  <view class="card">
    <view class="card-head">
      <view class="card-title">因子浓度曲线</view>
      <view class="tabs">
        <view class="tab {{chartMode==='day' ? 'active' : ''}}" bindtap="switchToDay">当天</view>
        <view class="tab {{chartMode==='week' ? 'active' : ''}}" bindtap="switchToWeek">一周</view>
      </view>
    </view>
    <canvas type="2d" id="chartCanvas" canvas-id="chartCanvas" class="chart"></canvas>
    <view class="muted">纵轴固定：0%~120%，曲线表示因子浓度随时间变化</view>
  </view>

  <view class="tabbar">
    <view class="tab-item active" data-key="home" bindtap="switchTab">
      <text class="tab-icon">⌂</text>
      <text class="tab-text">首页</text>
    </view>
    <view class="tab-item" data-key="history" bindtap="switchTab">
      <text class="tab-icon">☰</text>
      <text class="tab-text">历史记录</text>
    </view>
    <view class="tab-item" data-key="add" bindtap="switchTab">
      <view class="tab-icon tab-add-icon">＋</view>
      <text class="tab-text">新增</text>
    </view>
    <view class="tab-item" data-key="medicine" bindtap="switchTab">
      <text class="tab-icon">⚙</text>
      <text class="tab-text">药品维护</text>
    </view>
    <view class="tab-item" data-key="profile" bindtap="switchTab">
      <text class="tab-icon">◯</text>
      <text class="tab-text">我的</text>
    </view>
  </view>
</view>
