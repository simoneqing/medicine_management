.container { padding: 24rpx; padding-bottom: 180rpx; background: #F7FAFC; min-height: 100vh; box-sizing: border-box; }
.header { background: #4DA3FF; border-radius: 20rpx; padding: 28rpx 24rpx; color:#FFFFFF; margin-bottom: 20rpx; border: 1rpx solid #7BBEFF; }
.header-title { font-size: 38rpx; font-weight: 700; line-height: 1.25; }
.header-subtitle { margin-top: 12rpx; font-size: 24rpx; color:#EAF4FF; }
.grid-two { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; margin-bottom: 16rpx; }
.card { background:#fff; border-radius: 16rpx; padding: 20rpx; margin-bottom: 16rpx; border: 1rpx solid #e5e7eb; box-shadow: 0 4rpx 10rpx rgba(15,23,42,0.04); }
.card-title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; }
.row { display: flex; justify-content: space-between; margin-bottom: 14rpx; color:#1f2a37; font-size: 26rpx; }
.row text:first-child { padding-right: 12rpx; }
.value { font-weight: 600; }
.conc-row { display: flex; align-items: center; justify-content: space-between; }
.conc-label { font-size: 30rpx; font-weight: 600; color:#1f2a37; }
.conc { font-size: 56rpx; color:#2B7DE0; font-weight: 800; line-height: 1; text-align: right; }
.muted { color:#8A8A8A; font-size: 24rpx; line-height: 1.5; }
.recent-row { display: flex; justify-content: space-between; align-items: center; font-size: 22rpx; color: #8A8A8A; margin-bottom: 12rpx; gap: 12rpx; }
.recent-left, .recent-right { width: 50%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.recent-right { text-align: right; }
.card-head { display:flex; justify-content: space-between; align-items:center; margin-bottom: 16rpx; }
.tabs { display:flex; border:1px solid #EAF4FF; border-radius:999rpx; overflow:hidden; }
.tab { padding: 8rpx 18rpx; font-size: 22rpx; color:#6b7280; }
.tab.active { background:#2B7DE0; color:#fff; }
.chart { width: 100%; height: 500rpx; border-radius: 12rpx; background: #ffffff; margin-bottom: 10rpx; }
.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top: 1rpx solid #e5e7eb;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  align-items: end;
  padding: 10rpx 0 calc(env(safe-area-inset-bottom) + 10rpx);
  z-index: 100;
}
.tab-item, .tab-add-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; color: #6b7280; }
.tab-item.active { color: #2B7DE0; }
.tab-icon { font-size: 34rpx; line-height: 1; margin-bottom: 6rpx; }
.tab-text { font-size: 20rpx; }
.tab-add-wrap { transform: translateY(-18rpx); }
.tab-add {
  width: 92rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 50%;
  background: #f4d83f;
  color: #1f2937;
  font-size: 58rpx;
  padding: 0;
  margin: 0;
  border: 8rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.18);
}
.tab-add::after { border: none; }
