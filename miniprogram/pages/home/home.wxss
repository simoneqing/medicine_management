.container { padding: 24rpx; background: #f6f8fb; min-height: 100vh; }
.header { background: #fff; border-radius: 16rpx; padding: 22rpx 24rpx; color:#1f2a37; margin-bottom: 18rpx; border: 1rpx solid #e5e7eb; box-shadow: 0 2rpx 10rpx rgba(15,23,42,0.03); }
.header-title { font-size: 34rpx; font-weight: 700; line-height: 1.3; }
.header-subtitle { margin-top: 8rpx; font-size: 24rpx; color:#6b7280; }
.grid-two { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; margin-bottom: 16rpx; }
.card { background:#fff; border-radius: 16rpx; padding: 20rpx; margin-bottom: 16rpx; border: 1rpx solid #e5e7eb; box-shadow: 0 4rpx 10rpx rgba(15,23,42,0.04); }
.card-title { font-size: 30rpx; font-weight: 600; margin-bottom: 12rpx; }
.row { display: flex; justify-content: space-between; margin-bottom: 10rpx; color:#1f2a37; font-size: 26rpx; }
.value { font-weight: 600; display: inline-flex; align-items: baseline; gap: 8rpx; }
.num { font-size: 36rpx; font-weight: 700; color:#1f2a37; }
.unit { font-size: 22rpx; color:#9ca3af; }
.conc { display: inline-flex; align-items: baseline; gap: 10rpx; margin-bottom: 8rpx; }
.conc-num { font-size: 64rpx; color:#7C7AF7; font-weight: 800; line-height: 1; }
.conc-unit { font-size: 30rpx; color:#9ca3af; }
.muted { color:#6b7280; font-size: 24rpx; }
.card-head { display:flex; justify-content: space-between; align-items:center; margin-bottom: 10rpx; }
.tabs { display:flex; border:1px solid #e5e7eb; border-radius:999rpx; overflow:hidden; }
.tab { padding: 8rpx 18rpx; font-size: 22rpx; color:#6b7280; }
.tab.active { background:#F3F2FF; color:#7C7AF7; font-weight: 600; }
.chart { width: 100%; height: 400rpx; border-radius: 12rpx; background: #ffffff; }
.actions {
  display: grid;
  gap: 12rpx;
}
.sub-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}
.sub-actions .action {
  font-size: 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 6rpx;
}
.action {
  margin: 0;
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  font-size: 28rpx;
  background:#fff;
  color:#1f2a37;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
}
.action::after { border: none; }
.action.primary {
  background:#7C7AF7;
  color:#fff;
  border: none;
}
.action.primary:active { background:#6A68E6; }
.main-action { height: 84rpx; line-height: 84rpx; font-size: 30rpx; border-radius: 16rpx; }
