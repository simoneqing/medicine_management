.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 22rpx 22rpx calc(env(safe-area-inset-bottom) + 136rpx);
  background: #F7FAFC;
}
.home-content {
  min-height: calc(100vh - env(safe-area-inset-bottom) - 136rpx);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 16rpx;
}
.header { background: #4DA3FF; border-radius: 20rpx; padding: 24rpx 24rpx; color:#FFFFFF; border: 1rpx solid #7BBEFF; }
.header-title { font-size: 38rpx; font-weight: 700; line-height: 1.3; }
.grid-two { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; }
.stats-grid { margin-top: 2rpx; }
.card { background:#fff; border-radius: 18rpx; padding: 20rpx; border: 1rpx solid #e5e7eb; box-shadow: 0 4rpx 10rpx rgba(15,23,42,0.04); }
.stats-card { padding: 22rpx 20rpx; }
.card-title { font-size: 30rpx; font-weight: 600; margin-bottom: 14rpx; }
.row { display: flex; justify-content: space-between; margin-bottom: 12rpx; color:#1f2a37; font-size: 26rpx; line-height: 1.45; }
.row text:first-child { padding-right: 12rpx; }
.row:last-child { margin-bottom: 0; }
.value { font-weight: 600; }
.concentration-card { margin-top: 2rpx; padding-top: 22rpx; padding-bottom: 22rpx; }
.conc { font-size: 58rpx; color:#2B7DE0; font-weight: 800; line-height: 1.12; margin-bottom: 14rpx; }
.muted { color:#8A8A8A; font-size: 24rpx; line-height: 1.5; }
.recent-row { display: flex; justify-content: space-between; align-items: center; font-size: 22rpx; color: #8A8A8A; margin-bottom: 8rpx; gap: 12rpx; line-height: 1.6; }
.recent-left, .recent-right { width: 50%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.recent-right { text-align: right; }
.chart-card { margin-top: 2rpx; padding-top: 24rpx; padding-bottom: 20rpx; }
.card-head { display:flex; justify-content: space-between; align-items:center; margin-bottom: 16rpx; }
.tabs { display:flex; border:1px solid #EAF4FF; border-radius:999rpx; overflow:hidden; }
.tab { padding: 9rpx 20rpx; font-size: 22rpx; color:#6b7280; }
.tab.active { background:#2B7DE0; color:#fff; }
.chart { width: 100%; height: 430rpx; border-radius: 12rpx; background: #ffffff; margin: 6rpx 0 8rpx; }
.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top: 1rpx solid #e5e7eb;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  align-items: end;
  padding: 8rpx 0 calc(env(safe-area-inset-bottom) + 8rpx);
  z-index: 100;
}
.tab-item { display: flex; flex-direction: column; align-items: center; justify-content: center; color: #6b7280; }
.tab-item.active { color: #2B7DE0; }
.tab-icon { font-size: 34rpx; line-height: 1; margin-bottom: 6rpx; width: 44rpx; text-align: center; }
.tab-text { font-size: 20rpx; }
.tab-add-icon {
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #2B7DE0;
  color: #2B7DE0;
  font-size: 34rpx;
  margin: 0 0 6rpx;
  box-sizing: border-box;
}
.tab-medicine-icon {
  position: relative;
  width: 36rpx;
  height: 28rpx;
  border: 2rpx solid currentColor;
  border-radius: 7rpx;
  box-sizing: border-box;
  margin-top: 3rpx;
  margin-bottom: 7rpx;
}
.tab-medicine-icon::before,
.tab-medicine-icon::after {
  content: '';
  position: absolute;
  background: currentColor;
}
.tab-medicine-icon::before {
  width: 14rpx;
  height: 2rpx;
  left: 9rpx;
  top: 8rpx;
}
.tab-medicine-icon::after {
  width: 2rpx;
  height: 8rpx;
  left: 15rpx;
  top: 5rpx;
}
