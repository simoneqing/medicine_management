.container { padding: 24rpx; background: #F7FAFC; min-height: 100vh; }
.header { background: #DDF1FF; border-radius: 20rpx; padding: 28rpx 24rpx; color:#1F2A37; margin-bottom: 20rpx; border: 1rpx solid #EAF4FF; }
.header-title { font-size: 38rpx; font-weight: 700; line-height: 1.25; }
.header-subtitle { margin-top: 12rpx; font-size: 24rpx; color:#6B7280; }
.grid-two { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; margin-bottom: 16rpx; }
.card { background:#fff; border-radius: 16rpx; padding: 20rpx; margin-bottom: 16rpx; border: 1rpx solid #e5e7eb; box-shadow: 0 4rpx 10rpx rgba(15,23,42,0.04); }
.card-title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; }
.row { display: flex; justify-content: space-between; margin-bottom: 14rpx; color:#1f2a37; font-size: 26rpx; }
.value { font-weight: 600; }
.conc { font-size: 56rpx; color:#2F86E8; font-weight: 800; margin-bottom: 14rpx; line-height: 1; }
.muted { color:#8A8A8A; font-size: 24rpx; line-height: 1.5; }
.card-head { display:flex; justify-content: space-between; align-items:center; margin-bottom: 16rpx; }
.tabs { display:flex; border:1px solid #EAF4FF; border-radius:999rpx; overflow:hidden; }
.tab { padding: 8rpx 18rpx; font-size: 22rpx; color:#6b7280; }
.tab.active { background:#4DA3FF; color:#fff; }
.chart { width: 100%; height: 430rpx; border-radius: 12rpx; background: #ffffff; margin-bottom: 10rpx; }
.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 4rpx;
}
.action {
  margin: 0;
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0;
  font-size: 28rpx;
  background:#fff;
  color:#1f2a37;
  border: 1rpx solid #EAF4FF;
  border-radius: 14rpx;
  white-space: nowrap;
}
.action::after { border: none; }
.action.primary {
  background:#4DA3FF;
  color:#fff;
  border: none;
}
