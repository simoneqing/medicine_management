<view class="container">
  <view class="card">
    <view class="title">个人信息</view>
    <view class="current-row">
      <text class="label">用户ID（尾号）</text>
      <text class="value">{{maskedUserId}}</text>
    </view>
    <view class="current-row">
      <text class="label">当前体重</text>
      <text class="value">{{profile.weight}} kg</text>
    </view>
    <view class="muted">体重会影响预计提升浓度与相关计算，请保持更新。</view>
  </view>

  <view class="card">
    <view class="title">体重管理</view>
    <view class="input-wrap">
      <input
        class="weight-input"
        type="digit"
        placeholder="请输入体重，例如 68.5"
        value="{{weightInput}}"
        bindinput="onWeightInput"
      />
      <text class="unit">kg</text>
    </view>
    <button class="save-btn" type="primary" loading="{{saving}}" disabled="{{saving || !canSave}}" bindtap="saveWeight">
      {{saving ? '保存中...' : '保存体重'}}
    </button>
    <view class="status {{statusType === 'error' ? 'error' : ''}}">{{statusText}}</view>
  </view>

  <view class="tabbar">
    <view class="tab-item" data-key="home" bindtap="switchTab"><text class="tab-icon">⌂</text><text class="tab-text">首页</text></view>
    <view class="tab-item" data-key="history" bindtap="switchTab"><text class="tab-icon">☰</text><text class="tab-text">历史记录</text></view>
    <view class="tab-item" data-key="add" bindtap="switchTab"><view class="tab-icon tab-add-icon">＋</view><text class="tab-text">新增</text></view>
    <view class="tab-item" data-key="medicine" bindtap="switchTab"><text class="tab-icon">⚙</text><text class="tab-text">药品维护</text></view>
    <view class="tab-item active" data-key="profile" bindtap="switchTab"><text class="tab-icon">◯</text><text class="tab-text">我的</text></view>
  </view>
</view>
