.container {
  min-height: 100vh;
  background: #F7FAFC;
  padding: 24rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #e5e7eb;
  box-shadow: 0 4rpx 10rpx rgba(15, 23, 42, 0.04);
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.current-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.label {
  font-size: 28rpx;
  color: #6b7280;
}

.value {
  font-size: 40rpx;
  font-weight: 800;
  color: #2B7DE0;
}

.muted {
  font-size: 24rpx;
  color: #6b7280;
}

.input-wrap {
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.weight-input {
  flex: 1;
  height: 84rpx;
  font-size: 30rpx;
}

.unit {
  font-size: 28rpx;
  color: #6b7280;
}

.save-btn {
  border-radius: 16rpx;
  font-size: 30rpx;
  background: #2B7DE0 !important;
}

.save-btn:active {
  background: #1F6FCC !important;
}

.status {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #2B7DE0;
  background: #EAF4FF;
  border-radius: 12rpx;
  padding: 12rpx 14rpx;
}

.status.error {
  color: #b91c1c;
  background: #fee2e2;
}

.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top: 1rpx solid #e5e7eb;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  align-items: end;
  padding: 10rpx 0 calc(env(safe-area-inset-bottom) + 10rpx);
  z-index: 100;
}
.tab-item { display: flex; flex-direction: column; align-items: center; justify-content: center; color: #6b7280; }
.tab-item.active { color: #2B7DE0; }
.tab-icon { font-size: 34rpx; line-height: 1; margin-bottom: 6rpx; width: 44rpx; text-align: center; }
.tab-text { font-size: 20rpx; }
.tab-add-icon {
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #2B7DE0;
  color: #2B7DE0;
  font-size: 34rpx;
  margin: 0 0 6rpx;
  box-sizing: border-box;
}
.tab-medicine-icon {
  position: relative;
  width: 36rpx;
  height: 28rpx;
  border: 2rpx solid currentColor;
  border-radius: 7rpx;
  box-sizing: border-box;
  margin-top: 3rpx;
  margin-bottom: 7rpx;
}
.tab-medicine-icon::before,
.tab-medicine-icon::after {
  content: '';
  position: absolute;
  background: currentColor;
}
.tab-medicine-icon::before {
  width: 14rpx;
  height: 2rpx;
  left: 9rpx;
  top: 8rpx;
}
.tab-medicine-icon::after {
  width: 2rpx;
  height: 8rpx;
  left: 15rpx;
  top: 5rpx;
}
