.container { padding: 24rpx; background: #f5f7fb; min-height: 100vh; }
.card { background: #fff; border-radius: 20rpx; padding: 20rpx; margin-bottom: 16rpx; }
.title, .section-title { font-size: 32rpx; font-weight: 700; margin-bottom: 10rpx; }
.muted { color: #6b7280; font-size: 24rpx; margin-bottom: 8rpx; }
.field { margin-bottom: 12rpx; }
.field text { display: block; font-size: 24rpx; margin-bottom: 6rpx; color: #374151; }
input { border: 1px solid #d1d5db; border-radius: 10rpx; padding: 10rpx 12rpx; font-size: 26rpx; }
.list-head { display: flex; justify-content: space-between; align-items: center; margin: 8rpx 0; }
.spec-row { display: grid; grid-template-columns: 1fr auto; gap: 10rpx; margin-bottom: 10rpx; }
.actions { display: grid; grid-template-columns: 1fr 1fr; gap: 10rpx; margin-top: 10rpx; }
.status { margin-top: 10rpx; background: #eff6ff; color: #2563eb; padding: 10rpx; border-radius: 10rpx; font-size: 24rpx; }
.item { border: 1px solid #e5e7eb; border-radius: 14rpx; padding: 14rpx; margin-bottom: 10rpx; }
.item-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.brand { font-size: 30rpx; font-weight: 600; }
.kv { display: flex; justify-content: space-between; font-size: 24rpx; margin-top: 6rpx; }
